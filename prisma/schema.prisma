generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  username   String   @unique
  password   String
  role       String   @default("user")
  email      String
  ssn        String
  creditCard String
  address    String
  createdAt  DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  author    String
  content   String
  createdAt DateTime @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  category    String
}
