# Vuln Art Shop - Environment Configuration
# Copy this file to .env and update values as needed

# Database (SQLite - default for direct installation)
DATABASE_URL="file:./dev.db"

# Application
NEXT_PUBLIC_APP_NAME="Vuln Art Shop"
NEXT_PUBLIC_VERSION="1.0.0"

# Security
SECRET_KEY="change_me_to_a_random_secret_key"

# Optional: For production
# DATABASE_URL="postgresql://user:password@localhost:5432/vulnart"
